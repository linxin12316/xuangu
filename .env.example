# 复制为 .env 后填写真实值；.env 已被 .gitignore 忽略，禁止提交真实密钥。
SCKEY=SCTxxxxx
TUSHARE_TOKEN=xxxxx

# 可选：DeepSeek API Key，用于快讯 LLM 点评（利好/利空 + 强度评分）
# 控制台：https://platform.deepseek.com/api_keys
# 模型 deepseek-chat，月费约 ¥2-3
# DEEPSEEK_API_KEY=sk_xxxxx

# 可选：如果本地目录不是 git 仓库，填写有 repo 权限的 GitHub token，
# 本地兜底推送成功后会用 API 上传 picks/<日期>.json 和 pushed flag，避免 GitHub 延迟任务重复推送。
GITHUB_TOKEN=ghp_xxxxx
